    {
      "type": "text",
      "id": "non_blocking_note",
      "x": 1521.6475858470767,
      "y": 640.6261960119069,
      "width": 684.375,
      "height": 60,
      "text": "Key invariant: shipment creation is best-effort after order persistence. \nCommerce succeeds even if GHN is temporarily down, so shipment retry is \nan operational concern instead of a checkout rollback.",
